@dataclass
class FetchResult:
    final_url: Optional[str]
    html: Optional[str]
    status: int
    content_type: str


async def fetch_html(session: aiohttp.ClientSession, url: str, timeout_s: float, retries: int, backoff_base: float) -> FetchResult:
    last = FetchResult(None, None, 0, "")
    for attempt in range(max(1, retries + 1)):
        try:
            async with session.get(url, timeout=aiohttp.ClientTimeout(total=timeout_s), allow_redirects=True) as r:
                ct = (r.headers.get("Content-Type") or "").lower()
                status = r.status
                if status >= 400:
                    last = FetchResult(str(r.url), None, status, ct)
                else:
                    if ct and ("text/html" not in ct and "application/xhtml" not in ct):
                        return FetchResult(str(r.url), None, status, ct)
                    txt = await r.text(errors="ignore")
                    return FetchResult(str(r.url), txt, status, ct)
        except (aiohttp.ClientError, asyncio.TimeoutError):
            pass
        except Exception:
            pass

        if attempt < retries:
            await asyncio.sleep(backoff_base * (2 ** attempt))

    return last


async def google_cse_find_website(
    session: aiohttp.ClientSession,
    company: str,
    api_key: str,
    cx: str,
    timeout_s: float,
    retries: int,
    backoff_base: float,
) -> str:
    endpoint = "https://www.googleapis.com/customsearch/v1"
    queries = [f"{company} official website", company]

    for q in queries:
        for attempt in range(max(1, retries + 1)):
            try:
                async with session.get(
                    endpoint,
                    params={"key": api_key, "cx": cx, "q": q, "num": 5},
                    timeout=aiohttp.ClientTimeout(total=timeout_s),
                ) as r:
                    data = await r.json(content_type=None)

                if isinstance(data, dict) and "error" in data:
                    code = (data["error"].get("code") or "")
                    msg = (data["error"].get("message") or "")
                    return f"__CSE_ERROR__::{code}::{msg}"

                items = (data.get("items") or []) if isinstance(data, dict) else []
                for item in items[:5]:
                    link = (item.get("link") or "").strip()
                    if not link.startswith("http"):
                        continue
                    if link.lower().endswith(".pdf"):
                        continue
                    if is_bad_website(link):
                        continue
                    return link

            except (aiohttp.ClientError, asyncio.TimeoutError):
                pass
            except Exception:
                pass

            if attempt < retries:
                await asyncio.sleep(backoff_base * (2 ** attempt))

    return ""


async def domain_guess_find_website(
    company: str,
    session: aiohttp.ClientSession,
    timeout_s: float,
    retries: int,
    backoff_base: float,
    region: str,
) -> str:
    name = (company or "").lower()
    name = re.sub(r"[^\w\s]", " ", name)
    for x in (
        "pte ltd", "pvt ltd", "private limited", "limited", "ltd", "sdn bhd", "bhd",
        "inc", "llc", "plc", "corp", "company", "group"
    ):
        name = name.replace(x, " ")
    name = re.sub(r"\s+", " ", name).strip()
    tokens = [t for t in name.split() if len(t) > 1]
    if not tokens:
        return ""

    bases = [tokens[0]]
    if len(tokens) >= 2:
        bases += [tokens[0] + tokens[1], tokens[0] + "-" + tokens[1]]

    ru = (region or "").upper()
    if ru == "SG":
        tlds = [".com.sg", ".sg", ".com"]
    elif ru == "MY":
        tlds = [".com.my", ".my", ".com"]
    else:
        tlds = [".com"]

    for b in bases:
        for tld in tlds:
            for pref in ("https://www.", "https://", "http://www.", "http://"):
                u = f"{pref}{b}{tld}"
                res = await fetch_html(session, u, timeout_s, retries, backoff_base)
                if res.final_url and not is_bad_website(res.final_url):
                    return res.final_url
    return ""


async def find_official_website(
    company: str,
    session: aiohttp.ClientSession,
    timeout_s: float,
    retries: int,
    backoff_base: float,
    region: str,
) -> Tuple[str, str]:
    guess = await domain_guess_find_website(company, session, timeout_s, retries, backoff_base, region)
    if guess and not is_bad_website(guess):
        return guess, "Guess"

    api_key = (GOOGLE_API_KEY or "").strip()
    cx = (GOOGLE_CX_ID or "").strip()
    if api_key and cx:
        res = await google_cse_find_website(session, company, api_key, cx, timeout_s, retries, backoff_base)
        if res.startswith("__CSE_ERROR__::"):
            return "", res.replace("__CSE_ERROR__::", "CSE error: ")
        if res:
            return res, "CSE"

    return "", "No website"


# -------------------------
# Crawl
# -------------------------
async def crawl_for_contacts(
    session: aiohttp.ClientSession,
    website: str,
    max_pages: int,
    region: str,
    timeout_s: float,
    retries: int,
    backoff_base: float,
    max_seconds: float,
    sleep_s: float,
    page_concurrency: int,
) -> Tuple[Set[str], Set[str], str, str]:
    t0 = time.time()

    website = normalize_url(website)
    if not website:
        return set(), set(), "", "No website"
    if is_bad_website(website):
        return set(), set(), "", "Bad website domain"

    home = await fetch_html(session, website, timeout_s, retries, backoff_base)
    if not home.final_url or not home.html:
        return set(), set(), "", "Homepage fetch failed"

    p = urlparse(home.final_url)
    base_url = f"{p.scheme}://{p.netloc}"

    emails_all: Set[str] = set()
    phones_all: Set[str] = set()
    best_addr = ""

    em, ph, addr, links = await asyncio.to_thread(parse_contacts_and_links, home.html, base_url, region)
    emails_all |= em
    phones_all |= ph
    if addr:
        best_addr = addr

    q = deque([home.final_url] + links)
    seen: Set[str] = set()

    sem = asyncio.Semaphore(max(1, page_concurrency))

    async def fetch_one(u: str) -> FetchResult:
        async with sem:
            return await fetch_html(session, u, timeout_s, retries, backoff_base)

    inflight: List[asyncio.Task] = []

    while q and len(seen) < max_pages:
        if time.time() - t0 > max_seconds:
            emails_all = {e for e in emails_all if not any(e.lower().endswith(x) for x in (".png", ".jpg", ".jpeg", ".webp", ".gif"))}
            return emails_all, phones_all, best_addr, "Timed out"

        url = q.popleft()
        if url in seen:
            continue
        seen.add(url)
        if url == home.final_url:
            continue

        inflight.append(asyncio.create_task(fetch_one(url)))

        if len(inflight) >= page_concurrency or not q or len(seen) >= max_pages:
            done, _ = await asyncio.wait(inflight, return_when=asyncio.ALL_COMPLETED)
            inflight = []

            for d in done:
                res = d.result()
                if res.final_url and res.html:
                    em2, ph2, addr2, links2 = await asyncio.to_thread(parse_contacts_and_links, res.html, base_url, region)
                    emails_all |= em2
                    phones_all |= ph2
                    if addr2 and not best_addr:
                        best_addr = addr2
                    for l in links2:
                        if l not in seen:
                            q.append(l)

            if sleep_s > 0 and q:
                await asyncio.sleep(sleep_s)

    emails_all = {e for e in emails_all if not any(e.lower().endswith(x) for x in (".png", ".jpg", ".jpeg", ".webp", ".gif"))}
    return emails_all, phones_all, best_addr, "OK"


# -------------------------
# Row processing + async pipeline
# -------------------------
async def process_company_row(
    sheet_row: int,
    company: str,
    cur_w: str,
    cur_e: str,
    cur_p: str,
    cur_a: str,
    args,
    http_session: aiohttp.ClientSession,
    website_cache: Dict[str, Tuple[str, str]],
    scrape_cache: Dict[str, Tuple[str, str, str, str]],
    cache_lock: asyncio.Lock,
) -> Tuple[int, Dict[str, str]]:
    needs_w = args.overwrite or (not cur_w) or is_bad_website(cur_w)
    needs_e = args.overwrite or (not cur_e)
    needs_p = args.overwrite or (not cur_p)
    needs_a = args.overwrite or (not cur_a)

    if not (needs_w or needs_e or needs_p or needs_a):
        return sheet_row, {}

    website = normalize_url(cur_w) if (cur_w and not is_bad_website(cur_w)) else ""
    src = ""
    key = company.strip().lower()

    if needs_w and not website:
        async with cache_lock:
            cached = website_cache.get(key)
        if cached:
            website, src = cached
        else:
            website, src = await find_official_website(
                company=company,
                session=http_session,
                timeout_s=args.timeout,
                retries=args.retries,
                backoff_base=args.backoff,
                region=args.region,
            )
            async with cache_lock:
                website_cache[key] = (website, src)

    emails_s = cur_e
    phones_s = cur_p
    addr_s = cur_a

    if not website:
        status = src if src else "No website"
        up = {"Status": status}
        if args.overwrite or not cur_w:
            up["Website"] = ""
        if args.overwrite or not cur_e:
            up["Email"] = ""
        if args.overwrite or not cur_p:
            up["Phone"] = ""
        if args.overwrite or not cur_a:
            up["Address"] = ""
        return sheet_row, up

    dom = registrable_domain(website)
    async with cache_lock:
        cached2 = scrape_cache.get(dom)

    if cached2:
        cached_emails, cached_phones, cached_addr, cached_status = cached2
        status = cached_status
        if needs_e:
            emails_s = cached_emails
        if needs_p:
            phones_s = cached_phones
        if needs_a:
            addr_s = cached_addr
    else:
        em_set, ph_set, addr_new, crawl_status = await crawl_for_contacts(
            session=http_session,
            website=website,
            max_pages=args.max_pages,
            region=args.region.upper(),
            timeout_s=args.timeout,
            retries=args.retries,
            backoff_base=args.backoff,
            max_seconds=args.max_seconds_per_company,
            sleep_s=args.sleep,
            page_concurrency=args.page_concurrency,
        )
        emails_new = "; ".join(sorted(em_set)) if em_set else ""
        phones_new = "; ".join(sorted(ph_set)) if ph_set else ""
        addr_new_s = addr_new or ""
        async with cache_lock:
            scrape_cache[dom] = (emails_new, phones_new, addr_new_s, crawl_status)

        status = crawl_status
        if needs_e:
            emails_s = emails_new
        if needs_p:
            phones_s = phones_new
        if needs_a:
            addr_s = addr_new_s

    up: Dict[str, str] = {"Status": f"{status} ({src})" if src and status == "OK" else status}
    if needs_w:
        up["Website"] = website
    if needs_e:
        up["Email"] = emails_s
    if needs_p:
        up["Phone"] = phones_s
    if needs_a:
        up["Address"] = addr_s

    return sheet_row, up


async def run_async_and_write(
    args,
    ws,
    values: List[List[str]],
    idx_company: int,
    idx_website: int,
    idx_email: int,
    idx_phone: int,
    idx_address: int,
    idx_status: int,
):
    start_row = max(2, args.start_row)
    total_rows = len(values)
    last_row = total_rows if args.limit <= 0 else min(total_rows, start_row + args.limit - 1)
    if last_row < start_row:
        return

    connector = aiohttp.TCPConnector(
        limit=max(10, args.concurrency * 6),
        ssl=False if args.insecure else None,
    )
    timeout = aiohttp.ClientTimeout(total=args.timeout)

    website_cache: Dict[str, Tuple[str, str]] = {}
    scrape_cache: Dict[str, Tuple[str, str, str, str]] = {}
    cache_lock = asyncio.Lock()

    work_q: asyncio.Queue = asyncio.Queue(maxsize=max(50, args.concurrency * 10))
    result_q: asyncio.Queue = asyncio.Queue()

    async with aiohttp.ClientSession(headers=DEFAULT_HEADERS, timeout=timeout, connector=connector) as http_session:
        async def producer():
            for sheet_row in range(start_row, last_row + 1):
                row = values[sheet_row - 1]
                company = cell(row, idx_company)
                if not company:
                    continue
                await work_q.put((
                    sheet_row,
                    company,
                    cell(row, idx_website),
                    cell(row, idx_email),
                    cell(row, idx_phone),
                    cell(row, idx_address),
                ))

            for _ in range(args.concurrency):
                await work_q.put(None)

        async def worker():
            while True:
                item = await work_q.get()
                if item is None:
                    work_q.task_done()
                    return

                sheet_row, company, cur_w, cur_e, cur_p, cur_a = item
                try:
                    row_out, up = await asyncio.wait_for(
                        process_company_row(
                            sheet_row, company, cur_w, cur_e, cur_p, cur_a,
                            args, http_session, website_cache, scrape_cache, cache_lock
                        ),
                        timeout=args.max_seconds_per_company + 10.0,
                    )
                    await result_q.put((row_out, up))
                except asyncio.TimeoutError:
                    await result_q.put((sheet_row, {"Status": "Timed out"}))
                except Exception as e:
                    await result_q.put((sheet_row, {"Status": f"Error: {type(e).__name__}"}))
                finally:
                    work_q.task_done()

       # replace the writer() inside run_async_and_write() with this version
        async def writer():
            pending: List[gspread.Cell] = []
            last_flush_ts = 0.0

            def _api_status(e: Exception) -> Optional[int]:
                resp = getattr(e, "response", None)
                if resp is None:
                    return None
                return getattr(resp, "status_code", None) or getattr(resp, "status", None)

            def _is_retryable(e: Exception) -> bool:
                if isinstance(e, APIError):
                    code = _api_status(e)
                    if code in (429, 500, 502, 503, 504):
                        return True
                    return False
                msg = str(e).lower()
                return ("429" in msg) or ("rate limit" in msg) or ("quota" in msg) or ("backend error" in msg)

            async def _update_cells_with_retry(batch: List[gspread.Cell]) -> None:
                delay = 1.0
                max_delay = 30.0
                attempts = 7  # total tries

                for i in range(attempts):
                    try:
                        await asyncio.to_thread(ws.update_cells, batch, value_input_option="RAW")
                        return
                    except Exception as e:
                        if not _is_retryable(e) or i == attempts - 1:
                            raise
                        jitter = random.uniform(0.0, 0.3)
                        await asyncio.sleep(min(max_delay, delay) + jitter)
                        delay *= 2.0

            async def flush():
                nonlocal pending, last_flush_ts
                if not pending:
                    return

                # keep write requests under ~60/min
                now = time.time()
                min_interval = 1.1
                wait = (last_flush_ts + min_interval) - now
                if wait > 0:
                    await asyncio.sleep(wait)

                batch = pending
                pending = []
                await _update_cells_with_retry(batch)
                last_flush_ts = time.time()

            while True:
                item = await result_q.get()
                try:
                    if item is None:
                        break

                    sheet_row, up = item
                    if not up:
                        continue

                    if "Website" in up:
                        pending.append(gspread.Cell(sheet_row, idx_website + 1, up["Website"]))
                    if "Email" in up:
                        pending.append(gspread.Cell(sheet_row, idx_email + 1, up["Email"]))
                    if "Phone" in up:
                        pending.append(gspread.Cell(sheet_row, idx_phone + 1, up["Phone"]))
                    if "Address" in up:
                        pending.append(gspread.Cell(sheet_row, idx_address + 1, up["Address"]))
                    if "Status" in up:
                        pending.append(gspread.Cell(sheet_row, idx_status + 1, up["Status"]))

                    if up.get("Status"):
                        print(f"[row {sheet_row}] {up['Status']}", flush=True)

                    if len(pending) >= args.batch_cells:
                        await flush()
                finally:
                    result_q.task_done()

            await flush()
          


        prod_task = asyncio.create_task(producer())
        worker_tasks = [asyncio.create_task(worker()) for _ in range(args.concurrency)]
        writer_task = asyncio.create_task(writer())

        await prod_task
        await work_q.join()
        await asyncio.gather(*worker_tasks)

        await result_q.put(None)
        await writer_task


