def load_cse_credentials() -> Tuple[str, str]:
    try:
        from cse_credentials import GOOGLE_API_KEY, GOOGLE_CX_ID  # type: ignore
        return (str(GOOGLE_API_KEY or "").strip(), str(GOOGLE_CX_ID or "").strip())
    except ImportError:
        api_key = (os.getenv("GOOGLE_API_KEY") or os.getenv("GOOGLE_CSE_API_KEY") or "").strip()
        cx = (os.getenv("GOOGLE_CX_ID") or os.getenv("GOOGLE_CSE_CX") or "").strip()
        return api_key, cx
    except Exception as e:
        raise RuntimeError(f"cse_credentials.py exists but failed to import: {type(e).__name__}: {e}") from e


