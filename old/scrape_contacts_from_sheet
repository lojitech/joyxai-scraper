def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--sheet-id", required=True)
    ap.add_argument("--gid", type=int, default=None)
    ap.add_argument("--service-account", required=True)

    ap.add_argument("--region", default="SG")
    ap.add_argument("--max-pages", type=int, default=4)
    ap.add_argument("--timeout", type=float, default=18.0)
    ap.add_argument("--retries", type=int, default=1)
    ap.add_argument("--backoff", type=float, default=0.4)
    ap.add_argument("--sleep", type=float, default=0.15)
    ap.add_argument("--max-seconds-per-company", type=float, default=25.0)
    ap.add_argument("--start-row", type=int, default=2)
    ap.add_argument("--limit", type=int, default=0)
    ap.add_argument("--overwrite", action="store_true")
    ap.add_argument("--batch-cells", type=int, default=300)

    ap.add_argument("--concurrency", type=int, default=8)
    ap.add_argument("--page-concurrency", type=int, default=4)
    ap.add_argument("--insecure", action="store_true")
    args = ap.parse_args()

    gc = gspread.service_account(filename=args.service_account)
    sh = gc.open_by_key(args.sheet_id)
    ws = open_worksheet(sh, args.gid)

    values = ws.get_all_values()
    if not values:
        raise RuntimeError("Worksheet is empty.")

    headers = values[0]

    idx_company = find_header_index(headers, ["Company", "COMPANY", "Company Name", "Name"])
    idx_website = find_website_index_strict(headers)
    idx_email = find_header_index(headers, ["Email", "EMAIL", "Emails", "E-mail", "E-Mail"])
    idx_phone = find_header_index(headers, ["Phone", "PHONE", "Phones", "Telephone", "Tel"])
    idx_address = find_header_index(headers, ["Address", "ADDRESS"])
    idx_status = find_header_index(headers, ["Status", "STATUS"])

    if idx_company is None:
        raise RuntimeError("Company column not found (Company/COMPANY/Company Name/Name).")

    required: List[str] = []
    if idx_website is None:
        required.append("Website")
    if idx_email is None:
        required.append("Email")
    if idx_phone is None:
        required.append("Phone")
    if idx_address is None:
        required.append("Address")
    if idx_status is None:
        required.append("Status")

    if required:
        headers = ensure_columns(ws, headers, required)
        idx_website = find_website_index_strict(headers)
        idx_email = find_header_index(headers, ["Email", "EMAIL", "Emails", "E-mail", "E-Mail"])
        idx_phone = find_header_index(headers, ["Phone", "PHONE", "Phones", "Telephone", "Tel"])
        idx_address = find_header_index(headers, ["Address", "ADDRESS"])
        idx_status = find_header_index(headers, ["Status", "STATUS"])

    if None in (idx_website, idx_email, idx_phone, idx_address, idx_status):
        raise RuntimeError("Website/Email/Phone/Address/Status columns not found/created.")

    asyncio.run(
        run_async_and_write(
            args=args,
            ws=ws,
            values=values,
            idx_company=idx_company,
            idx_website=idx_website,
            idx_email=idx_email,
            idx_phone=idx_phone,
            idx_address=idx_address,
            idx_status=idx_status,
        )
    )


if __name__ == "__main__":
    main()
