def soup_from_html(html: str) -> BeautifulSoup:
    try:
        return BeautifulSoup(html, "lxml")
    except FeatureNotFound:
        return BeautifulSoup(html, "html.parser")


def extract_emails_from_text(text: str) -> Set[str]:
    found = set(m.group(0).lower() for m in EMAIL_RE.finditer(text or ""))
    for m in OBFUSCATED_EMAIL_RE.finditer(text or ""):
        found.add(f"{m.group(1)}@{m.group(2)}.{m.group(3)}".lower())
    return {e for e in found if len(e) <= 254 and ".." not in e}


def extract_phones_from_text(text: str, region: str) -> Set[str]:
    phones: Set[str] = set()
    if not text:
        return phones
    try:
        for match in PhoneNumberMatcher(text, region):
            num = match.number
            if phonenumbers.is_possible_number(num) and phonenumbers.is_valid_number(num):
                phones.add(phonenumbers.format_number(num, phonenumbers.PhoneNumberFormat.E164))
    except Exception:
        # PhoneNumberMatcher can throw on pathological input; skip rather than poisoning results
        return phones
    return phones


def extract_address_from_text(text: str, region: str) -> str:
    if not text:
        return ""
    rules = ADDRESS_RULES.get((region or "").upper(), ADDRESS_RULES["SG"])
    country_re = rules["country_re"]
    postal_re = rules["postal_re"]

    lines = [ln.strip() for ln in re.split(r"[\r\n]+", text) if ln and ln.strip()]

    for ln in lines:
        if country_re.search(ln) and postal_re.search(ln):
            ln2 = re.sub(r"\s+", " ", ln).strip()
            return ln2[:220] if len(ln2) > 220 else ln2

    for ln in lines:
        if country_re.search(ln) and len(ln) <= 160:
            ln2 = re.sub(r"\s+", " ", ln).strip()
            return ln2

    return ""


def extract_jsonld_contacts_and_address(soup: BeautifulSoup, region: str) -> Tuple[Set[str], Set[str], str]:
    emails: Set[str] = set()
    phones: Set[str] = set()
    best_addr = ""

    def maybe_addr(s: str):
        nonlocal best_addr
        if best_addr:
            return
        cand = extract_address_from_text(s, region)
        if cand:
            best_addr = cand

    def walk(obj):
        nonlocal emails, phones
        if isinstance(obj, dict):
            for k, v in obj.items():
                lk = str(k).lower()
                if lk in ("email", "e-mail"):
                    if isinstance(v, str):
                        emails |= extract_emails_from_text(v)
                    elif isinstance(v, list):
                        for x in v:
                            if isinstance(x, str):
                                emails |= extract_emails_from_text(x)
                if lk in ("telephone", "tel", "phone", "contactnumber", "contact_number"):
                    if isinstance(v, str):
                        phones |= extract_phones_from_text(v, region)
                    elif isinstance(v, list):
                        for x in v:
                            if isinstance(x, str):
                                phones |= extract_phones_from_text(x, region)
                if lk in ("address", "streetaddress", "postalcode", "addresslocality", "addressregion", "addresscountry"):
                    if isinstance(v, str):
                        maybe_addr(v)
                    elif isinstance(v, dict):
                        maybe_addr(json.dumps(v, ensure_ascii=False))
                walk(v)
        elif isinstance(obj, list):
            for x in obj:
                walk(x)

    for s in soup.find_all("script"):
        t = (s.get("type") or "").lower().strip()
        if t != "application/ld+json":
            continue
        raw = (s.string or s.get_text() or "").strip()
        if not raw:
            continue

        emails |= extract_emails_from_text(raw)
        phones |= extract_phones_from_text(raw, region)
        maybe_addr(raw)

        try:
            data = json.loads(raw)
            walk(data)
        except Exception:
            continue

    return emails, phones, best_addr


def parse_contacts_and_links(html: str, base_url: str, region: str) -> Tuple[Set[str], Set[str], str, List[str]]:
    raw = html or ""

    emails: Set[str] = set()
    phones: Set[str] = set()
    best_addr = ""

    emails |= extract_emails_from_text(raw)
    phones |= extract_phones_from_text(raw, region)
    best_addr = extract_address_from_text(raw, region) or best_addr

    soup = soup_from_html(raw)

    for a in soup.select("a[href^='mailto:']"):
        href = a.get("href", "")
        mail = href.split("mailto:", 1)[-1].split("?", 1)[0].strip().lower()
        if mail and EMAIL_RE.fullmatch(mail):
            emails.add(mail)

    for a in soup.select("a[href^='tel:']"):
        href = a.get("href", "")
        tel = href.split("tel:", 1)[-1].split("?", 1)[0].strip()
        if tel:
            phones.add(tel)

    em_ld, ph_ld, addr_ld = extract_jsonld_contacts_and_address(soup, region)
    emails |= em_ld
    phones |= ph_ld
    if addr_ld and not best_addr:
        best_addr = addr_ld

    for tag in soup(["style", "noscript"]):
        tag.extract()
    for s in soup.find_all("script"):
        t = (s.get("type") or "").lower().strip()
        if t != "application/ld+json":
            s.extract()

    text = soup.get_text(separator="\n", strip=True)
    emails |= extract_emails_from_text(text)
    phones |= extract_phones_from_text(text, region)
    if not best_addr:
        best_addr = extract_address_from_text(text, region) or best_addr

    contact_links: List[str] = []
    extra_links: List[str] = []
    seen: Set[str] = set()

    def add_link(u: str, contactish: bool):
        if not u or u in seen:
            return
        seen.add(u)
        (contact_links if contactish else extra_links).append(u)

    for a in soup.find_all("a", href=True):
        href = (a.get("href") or "").strip()
        if not href or href.startswith("#"):
            continue
        abs_url = urljoin(base_url, href)
        if not abs_url.startswith("http"):
            continue
        if not same_site(abs_url, base_url):
            continue

        path_lc = (urlparse(abs_url).path or "").lower()
        anchor_lc = (a.get_text(" ", strip=True) or "").lower()
        contactish = any(k in path_lc for k in CONTACT_HINTS) or any(k in anchor_lc for k in CONTACT_HINTS)
        add_link(abs_url, contactish)

    return emails, phones, best_addr, contact_links + extra_links[:10]


